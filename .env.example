# Violence Detection System Configuration
# Copy this file to .env and modify as needed

# =============================================================================
# SECURITY SETTINGS (CRITICAL - MUST CONFIGURE FOR PRODUCTION)
# =============================================================================

# Flask secret key - MUST be set to a secure random value in production
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secure-secret-key-here

# Enable/disable debug mode (MUST be False in production)
FLASK_DEBUG=False

# CORS allowed origins (comma-separated)
# For development: http://localhost:3000,http://localhost:5001
# For production: https://yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5001

# Allow all CORS origins (ONLY for development, NEVER in production)
CORS_ALLOW_ALL=False

# =============================================================================
# RATE LIMITING
# =============================================================================

# Maximum requests per window
RATE_LIMIT_REQUESTS=10

# Window size in seconds
RATE_LIMIT_WINDOW=60

# =============================================================================
# API AUTHENTICATION (Optional)
# =============================================================================

# Enable API key authentication
API_KEY_ENABLED=False

# Valid API keys (comma-separated)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEYS=

# =============================================================================
# FILE UPLOAD SETTINGS
# =============================================================================

# Maximum file size in bytes (default: 50MB)
MAX_CONTENT_LENGTH=52428800

# Upload folder path
UPLOAD_FOLDER=static/uploads

# =============================================================================
# CACHING
# =============================================================================

# Enable result caching
CACHE_ENABLED=True

# Cache TTL in seconds (default: 1 hour)
CACHE_TTL=3600

# Maximum cache entries
CACHE_MAX_SIZE=100

# =============================================================================
# MODEL CONFIGURATION
# =============================================================================

# Enable lazy model loading (loads on first use)
LAZY_LOAD_MODELS=True

# Model cache TTL in seconds (0 = never expire)
MODEL_CACHE_TTL=0

# Override default models (optional)
# TEXT_MODEL=unitary/toxic-bert
# IMAGE_MODEL=Falconsai/nsfw_image_detection
# AUDIO_MODEL=MIT/ast-finetuned-audioset-10-10-0.4593

# =============================================================================
# LOGGING
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file path (optional, logs to stdout if not set)
# LOG_FILE=logs/app.log

# Log rotation settings
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# =============================================================================
# SERVER
# =============================================================================

# Server port
PORT=5001

# =============================================================================
# PRODUCTION DEPLOYMENT (gunicorn)
# =============================================================================
# Run with: gunicorn -w 4 -b 0.0.0.0:5001 "app:create_app()"
#
# Recommended gunicorn settings:
# - Workers: 2-4 x CPU cores
# - Worker class: sync (default) or gevent for async
# - Timeout: 120 (increase for long video processing)
#
# Example:
# gunicorn -w 4 --timeout 120 -b 0.0.0.0:5001 "app:create_app()"
